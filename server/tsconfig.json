{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./",
        "module": "commonjs",
        "target": "ES2020",
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "include": [
        "./**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}